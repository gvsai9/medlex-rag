# ===== REQUIRED =====
GEMINI_API_KEY=your_gemini_api_key_here   # Free at https://ai.google.dev

# ===== NEO4J (Free AuraDB) =====
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# ===== OPTIONAL =====
# LangSmith (for eval tracing, free tier)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=medlex-rag

# ===== APP CONFIG =====
APP_ENV=development
MAX_CONCURRENT_WORKERS=4
CHUNK_SIZE=512
CHUNK_OVERLAP=51
TOP_K_RETRIEVAL=10
TOP_K_RERANK=3
FAISS_INDEX_PATH=data/index/faiss.index
SQLITE_DB_PATH=data/medlex.db
